#!/usr/bin/env zsh

# lsnoext lists files without any extension
function lsnoext(){
    find $1 -type f ! -name "*.*"
}

# source_or_error sources the file in $1 or outputs an error
function source_or_error(){
    if ! [ -f "$1" ]; then
        echo "source_or_error: $1 file doesn't exist"
        return 1
    fi

    source $1
}

# Per-key assignment (not PATHS+=( [k]=v ... )): the compound form trips
# `zsh -n` ("bad subscript for direct array assignment") in the test suite's
# syntax sweep; behavior is identical.
declare -A PATHS=()
PATHS[ZSH]="$HOME/.oh-my-zsh"
PATHS[ZSH_CUSTOM]="$HOME/.oh-my-zsh/custom"
PATHS[ZSH_CUSTOM_CONFIG_FILES]="$HOME/.config/zshrc/config"
PATHS[ZSH_CUSTOM_CONFIG_ALIASES]="$HOME/.config/zshrc/aliases"
PATHS[ZSH_CUSTOM_CONFIG_TEMPLATES]="$HOME/.config/zshrc/templates"
PATHS[ZSH_CUSTOM_CONFIG_NOTEBOOK]="$HOME/.config/zshrc/notebook.d"
PATHS[ZSH_CUSTOM_CONFIG_SCRIPTS]="$HOME/.config/zshrc/scripts"

for key in ${(k)PATHS}; do
    DIR=${PATHS[${key}]}

    if ! [ -d "$DIR" ]; then
        echo "routes: $DIR folder doesn't exist"
        continue
    fi

    export ${key}=$DIR
    if [ -f "$DIR/init" ]; then source_or_error $DIR/init ; fi
    # echo "${key}=${PATHS[${key}]}" # DEBUG
done

## Docker & k8s integrations are activated by default
# export DOCKER_SCRIPTS_PATH="integrations/docker_scripts"
source "$ZSH_CUSTOM_CONFIG_ALIASES/integrations/docker"
# source "$ZSH_CUSTOM_CONFIG_ALIASES/integrations/kubernetes"

# source "$ZSH_CUSTOM_CONFIG_ALIASES/integrations/javascript"
# source "$ZSH_CUSTOM_CONFIG_ALIASES/integrations/gcloud"

## Lazy PATH-only inits for interactive-only tools.
## First invocation sources the per-tool script and re-dispatches; subsequent
## calls resolve directly off PATH. Not suitable for tools that scripts invoke.
source_or_error "$ZSH_CUSTOM_CONFIG_ALIASES/lazy/_helper"
lazy_cmd opencode    "$ZSH_CUSTOM_CONFIG_ALIASES/lazy/opencode"
lazy_cmd lms         "$ZSH_CUSTOM_CONFIG_ALIASES/lazy/lms"
lazy_cmd antigravity "$ZSH_CUSTOM_CONFIG_ALIASES/lazy/antigravity"
