#!/bin/bash
# Once-a-day startup reminder of the homegrown tools, so they stay discoverable.
# Shown at most once per calendar day; a single stamp-file read, no startup cost.
# Silence entirely: touch ~/.cache/zsh-tip-off
() {
    local cache=${XDG_CACHE_HOME:-$HOME/.cache}
    [[ -f $cache/zsh-tip-off ]] && return
    local stamp=$cache/zsh-tip-day today
    zmodload zsh/datetime 2>/dev/null
    today=$(strftime '%Y%m%d' $EPOCHSECONDS 2>/dev/null) || today=$(date +%Y%m%d)
    [[ -r $stamp && "$(cat $stamp 2>/dev/null)" == $today ]] && return
    mkdir -p "$cache" 2>/dev/null
    print -r -- "$today" > "$stamp"

    {
        print -P "%F{8}── your tools ─────────────────────────────────────────%f"
        print -P "  %F{cyan}zshhelp%f   list all your custom commands (+ keyword filter)"
        print -P "  %F{cyan}zshperf%f   shell startup speed: waterfall · time · doctor"
        print -P "  %F{cyan}aispeak%f   talk to a local LLM by voice (--lang, --topic)"
        print -P "  %F{cyan}howto?%f    offline notebook topics (howto ask <t> for AI)"
        print -P "%F{8}──────────────────── once a day · touch ~/.cache/zsh-tip-off to mute%f"
    } >&2
}
