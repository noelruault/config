#!/bin/bash
# Scrub commands out of zsh history — the file AND the current session — for when
# you run one wrong and don't want to fish it back out of history later.
#   histrm                remove the last command
#   histrm -n N           remove the last N commands
#   histrm "<text>"       remove every history entry containing <text>
# It also drops the histrm call itself, so it never pollutes history.

# remove the last command (or matching entries) from zsh history
histrm() {
    emulate -L zsh
    local f=${HISTFILE:-$HOME/.zsh_history}
    [[ -w $f ]] || { print -u2 "histrm: cannot write $f"; return 1; }
    fc -AI 2>/dev/null                       # flush this session's commands to the file

    local tmp before after
    tmp=$(mktemp "${TMPDIR:-/tmp}/histrm.XXXXXX") || return 1
    before=$(grep -c '' "$f")

    # A history line is "self" (a histrm call) if its command is histrm ...
    local selfre='(^|;)[[:space:]]*histrm([[:space:]]|$)'

    # LC_ALL=C: the history file is "metafied" by zsh and contains raw non-UTF8
    # bytes; in a UTF-8 locale macOS awk dies on them mid-file ("towc: multibyte
    # conversion failure") and the truncated output would replace the history.
    local ok=0
    if [[ $1 == -n && $2 == <-> ]]; then
        # cut is in non-self-count space, not line-index space: a histrm call
        # sitting mid-history would otherwise inflate the cutoff and -n would
        # remove fewer entries than asked.
        LC_ALL=C awk -v n="$2" -v re="$selfre" '
            { L[NR]=$0; if ($0 !~ re) total++ }
            END { cut=total-n; c=0
                  for (i=1;i<=NR;i++){ if (L[i] ~ re) continue; c++; if (c>cut) continue; print L[i] } }
        ' "$f" > "$tmp" && ok=1
    elif (( $# )); then
        LC_ALL=C awk -v p="$*" -v re="$selfre" '
            { cmd=$0; sub(/^: [0-9]*:[0-9]*;/,"",cmd)
              if (cmd ~ re) next
              if (index(cmd,p)) next
              print }
        ' "$f" > "$tmp" && ok=1
    else
        LC_ALL=C awk -v re="$selfre" '
            { L[NR]=$0 }
            END { last=NR; while (last>0 && L[last] ~ re) last--
                  for (i=1;i<=NR;i++){ if (L[i] ~ re) continue; if (i==last) continue; print L[i] } }
        ' "$f" > "$tmp" && ok=1
    fi

    if (( ! ok )); then
        print -u2 "histrm: awk failed, history left untouched"
        command rm -f "$tmp"
        return 1
    fi

    after=$(grep -c '' "$tmp")
    command cp -p "$f" "${f}.histrm-bak"   # one-deep undo: previous history kept here
    command mv "$tmp" "$f"
    fc -p "$f" 2>/dev/null                   # reload the cleaned history into this session
    local d=$((before-after))
    print -P -u2 "%F{8}histrm: removed ${d} entr$([[ $d == 1 ]] && echo y || echo ies)%f"
}
